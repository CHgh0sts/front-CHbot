// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SiteRole {
  USER
  MODERATOR
  ADMIN
}

enum SubscriptionTier {
  FREE
  PREMIUM
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  discordId    String? @unique
  passwordHash String?

  siteRole SiteRole           @default(USER)
  tier     SubscriptionTier   @default(FREE)
  xp       Int                @default(0)
  level    Int                @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts           Account[]
  sessions           Session[]
  gameParticipations GameParticipation[]
  partyConfigPresets PartyConfigPreset[]
}

/// Configuration de partie créée sur le site ; code public 5 caractères pour `/lg-init preset:` Discord.
model PartyConfigPreset {
  id         String @id @default(cuid())
  /** Code alphanumérique 5 car. (A–Z, 2–9), unique */
  publicCode String @unique @db.VarChar(5)
  name       String?

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  /** Même structure que `CompositionConfig` du bot (JSON) */
  composition Json

  /** Premium : images par rôle — objet `{ mime, data }` (base64) et/ou URL HTTPS legacy. */
  roleImageOverrides Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

/// Images par défaut des cartes de rôle — base64 + MIME (upload sur le site).
model RoleCardDefault {
  roleKey     String   @id
  mimeType    String   @default("image/png")
  imageBase64 String   @db.Text
  updatedAt   DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model GameParticipation {
  id            String   @id @default(cuid())
  userId        String?
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  discordUserId String
  guildId       String
  channelId     String?
  endedAt       DateTime
  roleKey       String
  won           Boolean
  alive         Boolean
  xpAwarded     Int

  @@index([discordUserId])
  @@index([userId])
  @@index([endedAt])
}

model CompositionAccessRule {
  id             String           @id @default(cuid())
  compositionKey String           @unique
  minTier        SubscriptionTier @default(FREE)

  updatedAt DateTime @updatedAt
}
